generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?  @map("password_hash")
  googleId     String?  @unique @map("google_id")
  displayName  String   @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  inspirations Inspiration[]
  favorites    Favorite[]
  comments     Comment[]

  @@map("users")
}

model Inspiration {
  id           String      @id @default(cuid())
  title        String      @db.VarChar(200)
  description  String?     @db.Text
  contentText  String?     @map("content_text") @db.Text

  // Multi-value fields: String[] for flexible tagging.
  subject      String[]    @default(["other"])
  style        String[]    @default(["other"])
  mood         String[]    @default(["other"])
  scene        String[]    @default(["other"])
  audience     String[]    @default(["other"])
  difficulty   Difficulty
  timeEstimate TimeEstimate @map("time_estimate")

  tags Json @default("[]")

  generatedBy  String  @default("system") @map("generated_by")
  promptUsed   String? @db.Text            @map("prompt_used")
  modelVersion String? @map("model_version")

  likesCount      Int @default(0) @map("likes_count")
  copiesCount     Int @default(0) @map("copies_count")
  sharesCount     Int @default(0) @map("shares_count")
  viewsCount      Int @default(0) @map("views_count")
  favoritesCount  Int @default(0) @map("favorites_count")
  commentsCount   Int @default(0) @map("comments_count")

  userId       String? @map("user_id")
  sessionId    String? @map("session_id")
  status       String  @default("published")
  isAiGenerated Boolean @default(true) @map("is_ai_generated")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  publishedAt DateTime @default(now()) @map("published_at")

  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  favorites   Favorite[]
  comments    Comment[]
  interactions InspirationInteraction[]

  @@index([userId])
  @@index([sessionId])
  @@index([difficulty])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([likesCount(sort: Desc)])
  @@index([copiesCount(sort: Desc)])
  @@index([favoritesCount(sort: Desc)])
  @@map("inspirations")
}

model UserSession {
  id              String    @id @default(cuid())
  sessionId       String?   @unique @map("session_id")
  userId          String?   @unique @map("user_id")
  generatedCount  Int       @default(0) @map("generated_count")
  lastGeneratedAt DateTime? @map("last_generated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("user_sessions")
}

model InspirationInteraction {
  id              String   @id @default(cuid())
  inspirationId   String   @map("inspiration_id")
  sessionId       String   @map("session_id")
  interactionType String   @map("interaction_type")
  createdAt       DateTime @default(now()) @map("created_at")

  inspiration Inspiration @relation(fields: [inspirationId], references: [id], onDelete: Cascade)

  @@unique([inspirationId, sessionId, interactionType])
  @@index([inspirationId])
  @@index([sessionId])
  @@map("inspiration_interactions")
}

model Favorite {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  inspirationId String   @map("inspiration_id")
  createdAt     DateTime @default(now()) @map("created_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  inspiration Inspiration @relation(fields: [inspirationId], references: [id], onDelete: Cascade)

  @@unique([userId, inspirationId])
  @@index([userId])
  @@index([inspirationId])
  @@map("favorites")
}

model PendingRegistration {
  id           String   @id @default(cuid())
  email        String   @unique
  code         String
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("pending_registrations")
}

model Comment {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  inspirationId String   @map("inspiration_id")
  parentId      String?  @map("parent_id")
  content       String   @db.Text
  imageUrl      String?  @map("image_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  inspiration Inspiration @relation(fields: [inspirationId], references: [id], onDelete: Cascade)
  parent      Comment?    @relation("CommentToParent", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[]   @relation("CommentToParent")

  @@index([inspirationId])
  @@index([parentId])
  @@index([userId])
  @@map("comments")
}

enum Difficulty {
  beginner
  easy
  medium
  hard
}

enum TimeEstimate {
  min_5       @map("5min")
  min_15      @map("15min")
  min_30      @map("30min")
  hour_1      @map("1hour")
  hour_2_plus @map("2hour_plus")
}

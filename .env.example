# ===== Database (Supabase PostgreSQL) =====
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Supabase public (only needed if using supabase-js in the browser)
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# ===== AI =====
# Get your key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY="sk-..."

# ===== App =====
# Public base URL — used for absolute links in sitemap, robots, OG tags.
# Must match the canonical domain (no trailing slash).
NEXT_PUBLIC_BASE_URL="https://drawspark.art"

# ===== Analytics (optional) =====
# Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=""
# Google Search Console HTML-tag verification token (the part inside content="...")
NEXT_PUBLIC_GSC_VERIFICATION=""
# Bing Webmaster Tools verification token (the part inside content="...")
NEXT_PUBLIC_BING_VERIFICATION=""
# Bing UET (Universal Event Tracking) Tag ID, e.g. 12345678
# Get it from https://ads.microsoft.com → Conversion Tracking → UET tags
NEXT_PUBLIC_BING_UET_ID=""

# ===== On-demand cache bust =====
# Shared secret for POST /api/revalidate. If unset, the endpoint refuses
# all requests. Generate with: openssl rand -hex 32
REVALIDATE_SECRET=""